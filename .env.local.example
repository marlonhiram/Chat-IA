# Copie este arquivo para .env.local e preencha com suas credenciais
# cp .env.local.example .env.local

# Google Gemini — https://aistudio.google.com/
GEMINI_API_KEY=sua_chave_gemini_aqui

# Google Sheets — Service Account (Google Cloud Console)
GOOGLE_SERVICE_ACCOUNT_EMAIL=sua-service-account@projeto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_PRIVADA_AQUI\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=id_da_sua_planilha_google_sheets

# Painel de monitoramento — senha de acesso em /painel
PAINEL_SENHA=sua_senha_aqui

# (Opcional) URL da API para o widget embeddable
# NEXT_PUBLIC_CHAT_API_URL=https://seu-projeto.vercel.app
